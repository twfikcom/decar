# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public site URL (löwetrucks.de or xn--lwetrucks-07a.de — both OK)
APP_URL="https://löwetrucks.de"

# WordPress inventory API (admin subdomain). Next.js fetches JSON from here on each request / ISR window.
WORDPRESS_API_URL="https://admin.löwetrucks.de"
# Seconds between cached WordPress responses (0 = always fetch fresh, no CDN cache)
WORDPRESS_REVALIDATE_SECONDS=60

# Public prices: omit or false = hide EUR prices, show “Ask price” → WhatsApp (default). Set true to show prices.
NEXT_PUBLIC_SHOW_PRICES=false
# WhatsApp E.164 without + (used for ask-price links when prices are hidden).
NEXT_PUBLIC_WHATSAPP_E164=491625330280
