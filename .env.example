# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public site URL (löwetrucks.de or xn--lwetrucks-07a.de — both OK)
APP_URL="https://löwetrucks.de"

# WordPress inventory API (admin subdomain)
WORDPRESS_API_URL="https://admin.löwetrucks.de"
WORDPRESS_REVALIDATE_SECONDS=60

# Shared secret for /api/revalidate (must match Löwe Inventory plugin settings)
REVALIDATE_SECRET="change-me-to-a-long-random-string"
