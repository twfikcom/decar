# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public site URL (löwetrucks.de or xn--lwetrucks-07a.de — both OK)
APP_URL="https://löwetrucks.de"

# WordPress REST API (inventory: trucks & cars)
# Admin panel: https://admin.löwetrucks.de
WORDPRESS_API_URL="https://admin.löwetrucks.de"
WORDPRESS_REVALIDATE_SECONDS=60

# Shared secret between WordPress plugin and Next.js (Löwe Inventory → Next.js Sync)
REVALIDATE_SECRET="change-me-to-a-long-random-string"
